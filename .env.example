# ─────────────────────────────────────────────────────────────
#  SDN-QoSec – Project Configuration  (.env)
#  Copy this file to .env and adjust values as needed.
# ─────────────────────────────────────────────────────────────

# ── QoSec Cost-Function Tuning Parameters ────────────────────
QOSEC_ALPHA=0.4          # Weight: normalised link distance
QOSEC_BETA=0.4           # Weight: inverse key-buffer level
QOSEC_GAMMA=0.2          # Weight: QBER exponential penalty
QOSEC_ETA=10             # Exponent multiplier for QBER term
QOSEC_K_THRESHOLD=200    # Target key reserve (bits); used in β term
QOSEC_K_MIN=50           # Link pruned from graph below this level (bits)

# ── Simulation Parameters ─────────────────────────────────────
SIM_TICKS=500            # Total simulation ticks
SIM_TICK_MS=10           # Wall-clock ms per tick (for real-time pacing)
KEY_GEN_RATE_BPS=10000   # Base quantum key generation rate (10 kbps)
KEY_BUFFER_MAX=5000      # Maximum key buffer per link (bits)

# ── Traffic Generator ─────────────────────────────────────────
TRAFFIC_LAMBDA=2         # Poisson λ – mean key requests per tick

# ── Adversary (Eve) ───────────────────────────────────────────
EVE_INTERVAL_TICKS=100   # How often Eve attacks a link
EVE_QBER_SPIKE=0.15      # QBER injected by Intercept-Resend attack

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
